        "# 10989 수 정렬하기3\n",
        "n=int(input())\n",
        "result=[0] * 10001\n",
        "for i in range(n):\n",
        "  number=int(input())\n",
        "  result[number]+=1\n",
        "\n",
        "for i in range(10001):\n",
        "  if result[i]!=0:\n",
        "    for _ in range(result[i]):\n",
        "      print(i)"
