        "# 2903 중앙 이동 알고리즘\n",
        "dot=[0 for i in range(100)]\n",
        "dot[0]=2\n",
        "for i in range(1,100):\n",
        "  dot[i]=2*dot[i-1]-1\n",
        "N=int(input())\n",
        "print(dot[N]**2)"
