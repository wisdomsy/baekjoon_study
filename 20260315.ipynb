        "# 14215 세 막대\n",
        "\n",
        "a,b,c=map(int,input().split())\n",
        "long=max(a,b,c)\n",
        "origin=a+b+c-long\n",
        "if long>=a+b+c-long:\n",
        "  long=a+b+c-long-1\n",
        "print(origin+long)"
      ],
