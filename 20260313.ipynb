        "# 9063 대지\n",
        "n=int(input())\n",
        "x_list=[]\n",
        "y_list=[]\n",
        "for i in range(n):\n",
        "  x,y=map(int,input().split())\n",
        "  x_list.append(x)\n",
        "  y_list.append(y)\n",
        "x_list.sort()\n",
        "y_list.sort()\n",
        "print((x_list[-1]-x_list[0])*(y_list[-1]-y_list[0]))"
      ],
