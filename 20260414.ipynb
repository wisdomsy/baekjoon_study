        "# 11651 좌표 정렬하기2\n",
        "n=int(input())\n",
        "result=[]\n",
        "for i in range(n):\n",
        "  result.append(list(map(int,input().split())))\n",
        "\n",
        "result.sort(key=lambda p: (p[1],p[0])) #sort로 자동 정렬 -> lambda 이용해서 y 기준 설정\n",
        "for i in range(n):\n",
        "  print(result[i][0],result[i][1])"
      ],
