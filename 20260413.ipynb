        "# 11650 좌표 정렬하기\n",
        "n=int(input())\n",
        "result=[]\n",
        "for i in range(n):\n",
        "  result.append(list(map(int,input().split())))\n",
        "\n",
        "result.sort() #sort로 자동 정렬 -> 시간초과 문제 해결\n",
        "for i in range(n):\n",
        "  print(result[i][0],result[i][1])"
      ],
