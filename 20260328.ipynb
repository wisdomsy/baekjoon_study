      "source": [
        "# 2231 분해합\n",
        "n=int(input())\n",
        "for i in range(1,n):\n",
        "  sum=i\n",
        "  number=str(i)\n",
        "  for j in range(len(number)):\n",
        "    sum+=int(number[j])\n",
        "  if n==sum:\n",
        "    print(number)\n",
        "    break\n",
        "else:\n",
        "  print(0)"
      ],
