        "# 1181 단어 정렬\n",
        "n=int(input())\n",
        "result=[]\n",
        "\n",
        "for i in range(n):\n",
        "  word=input()\n",
        "  result.append(word)\n",
        "result = list(set(result))\n",
        "result.sort(key=lambda x: (len(x),x))\n",
        "\n",
        "for i in range(n):\n",
        "  print(result[i])"
