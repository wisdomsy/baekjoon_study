        "n=int(input())\n",
        "divide=2\n",
        "while True:\n",
        "  if n==1:\n",
        "    break\n",
        "  while True:\n",
        "    if n%divide==0:\n",
        "      n//=divide\n",
        "      print(divide)\n",
        "      divide=2\n",
        "      break\n",
        "    divide+=1"
